---
permalink: /sitemap.xml
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
{%- comment -%}
  Sitemap gerado automaticamente. O <lastmod> de cada URL vem da data do último
  commit que tocou a página (plugin jekyll-last-modified-at, via build no GitHub
  Actions). Caso o plugin não esteja disponível, cai para o campo
  `last_modified` do front matter. A lista de URLs e os links alternados
  (hreflang) são montados a partir de _data/pages.yml — sem edição manual aqui.
{%- endcomment -%}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
{%- for entry in site.data.pages -%}
  {%- assign key = entry[0] -%}
  {%- assign meta = entry[1] -%}
  {%- comment -%} Deriva a view (short/full) a partir da chave "<lang>-<view>". {%- endcomment -%}
  {%- assign view = key | split: "-" | last -%}
  {%- assign lang = key | split: "-" | first -%}
  {%- assign pt_key = view | prepend: "pt-" -%}
  {%- assign en_key = view | prepend: "en-" -%}
  {%- assign pt = site.data.pages[pt_key] -%}
  {%- assign en = site.data.pages[en_key] -%}
  {%- comment -%} Localiza a página correspondente para ler o last_modified. {%- endcomment -%}
  {%- assign lastmod = "" -%}
  {%- for page in site.pages -%}
    {%- if page.lang == lang and page.view == view -%}
      {%- assign lastmod = page.last_modified_at | default: page.last_modified -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  <url>
    <loc>{{ meta.canonical }}</loc>
    <xhtml:link rel="alternate" hreflang="pt-BR" href="{{ pt.canonical }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ en.canonical }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ pt.canonical }}"/>
    {%- if lastmod %}
    <lastmod>{{ lastmod | date: "%Y-%m-%d" }}</lastmod>
    {%- endif %}
  </url>
{%- endfor %}
</urlset>
